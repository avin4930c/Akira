ENVIRONMENT=development
LOG_LEVEL=debug

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/akira

LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=
LANGSMITH_TRACING=false

CORS_ORIGINS=["http://localhost:3000"]

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

GCP_PROJECT_ID=your_gcp_project_id
VERTEX_SERVICE_ACCOUNT_JSON_PATH=creds/your_service_account.jsonS

CLERK_JWT_PUBLIC_KEY=your_clerk_jwt_public_key_here

TAVILY_API_KEY=your_tavily_api_key_here

USE_LOCAL_EMBEDDINGS=false
LOCAL_EMBEDDING_DIMENSION=1024

LMSTUDIO_EMBEDDING_URL=http://127.0.0.1:1234
LMSTUDIO_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=[]

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

REDIS_HOST=localhost
REDIS_PORT=6379