dd() {
  echo -e "\n\n\e[31m$1\e[0m\n\n"
  exit 1
}

WEBCLIENT_CHANGED=$(git diff --cached --name-only | grep "^webclient/" || true)

if [ -n "$WEBCLIENT_CHANGED" ]; then
  echo "Webclient files changed, running build and tests..."
  cd webclient
  npm run build || dd "Build Failed"
  npm run test || dd "Tests Failed"
  cd ..
else
  echo "No webclient files changed, skipping build and tests."
fi